    {
        "id": "0de684535b765fe8",
        "type": "function",
        "z": "af2977090f3c297f",
        "name": "Recomendação",
        "func": "var p = msg.payload;\nvar rec = '';\nif (p.status === 'critico') {\n  if (p.temp > 40) rec = '❌ Calor extremo — adiar plantio e irrigar urgente';\n  else if (p.temp < 8) rec = '❄️ Risco de geada — proteger culturas imediatamente';\n  else rec = '❌ Solo crítico — irrigação imediata necessária';\n} else if (p.status === 'atencao') {\n  rec = '⚠️ Solo abaixo do ideal — planejar irrigação nas próximas 24h';\n} else {\n  rec = '✅ Condições favoráveis para plantio nas próximas 72h';\n}\nmsg.payload = rec;\nreturn msg;",
        "outputs": 1,
        "x": 420,
        "y": 460,
        "wires": [
            [
                "1f025d6b3046efd2"
            ]
        ]
    },
