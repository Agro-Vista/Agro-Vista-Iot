        "func": "var s = msg.payload.status;\nvar badges = {\n  'normal':  '🟢 NORMAL — Condições favoráveis',\n  'atencao': '🟡 ATENÇÃO — Monitorar talhão',\n  'critico': '🔴 CRÍTICO — Ação imediata necessária',\n  'online':  '🔵 Dispositivo online'\n};\nmsg.payload = badges[s] || '⚪ ' + s;\nreturn msg;",
